# All repos' traces consolidate into the robotsix-mill Langfuse project
# (per-repo `langfuse:` blocks are overridden). Sessions stay legible
# via repo-qualified ids (e.g. `robotsix-llmio · <ticket>`).
langfuse_shared_master: robotsix-mill

repos:
  robotsix-mill:
    board_id: robotsix-mill
    forge_remote_url: https://github.com/damien-robotsix/robotsix-mill
    langfuse:
      project_name: robotsix-mill
      public_key: pk-lf-bdf0c386-ee81-4ef2-b449-bfbfea6f15d8
      secret_key: sk-lf-9b18f7cd-f88b-4811-9bfd-2c067aa3ece9
      base_url: https://langfuse.robotsix.net
    max_concurrency: 2
  robotsix-auto-mail:
    board_id: robotsix-auto-mail
    forge_remote_url: https://github.com/damien-robotsix/robotsix-auto-mail
    deployed_log_folder: /home/robotsix/projects/Robotsix/robotsix-auto-mail/.mail_log
    langfuse:
      project_name: robotsix-auto-mail
      public_key: pk-lf-cea1dbf4-2911-4426-a204-dd2c03950e3a
      secret_key: sk-lf-3c2f4512-e826-4e90-9e3a-6f6af485e226
      base_url: https://langfuse.robotsix.net
  robotsix-llmio:
