# --- Core ---------------------------------------------------------------
# OpenRouter key used by all pydantic-ai agents.
OPENROUTER_API_KEY=

# The CHEAP DRIVER model: it orchestrates refine + implement (explore,
# assemble context, apply, verify) and delegates authoring to the
# strong deep_model. Keep it cheap AND multi-provider — a
# single-provider model (tencent/hy3-preview → only SiliconFlow)
# rate-limits (429) with no fallback and stalls the pipeline.
# deepseek-v4-flash is ~same price and has ~12 providers.
MILL_MODEL=deepseek/deepseek-v4-flash
# The strong AUTHORING model (deep_refine / deep_implement). Called as
# a tool with a complete curated context; returns the spec / code
# change. Never ":online", no tools, ~one-shot per call.
# MILL_DEEP_MODEL=deepseek/deepseek-v4-pro
# MILL_DEEP_MODEL_REQUEST_LIMIT=4
# Per-call cap for the read-only exploration sub-agent the driver uses
# instead of reading the repo into its own limited context.
# MILL_EXPLORE_REQUEST_LIMIT=20

# Where the SQLite DB and per-ticket workspaces live. Leave UNSET for
# local dev — the code defaults to a repo-local ./.mill-data/. The
# Docker image sets this to /data itself; only override for a custom
# path.
# MILL_DATA_DIR=/data

# --- Management-plane service ------------------------------------------
# Leave UNSET locally (code default 127.0.0.1). The Docker image sets
# this to 0.0.0.0 itself so the port is reachable from the host.
# MILL_API_HOST=0.0.0.0
MILL_API_PORT=8077
# Base URL the CLI client uses (inside the container).
MILL_API_URL=http://127.0.0.1:8077

# --- Web research sub-agent --------------------------------------------
# The expensive main agent NEVER uses OpenRouter ":online" (a
# per-request web-search surcharge that cost a real ticket ~$3). Web
# search is delegated to a cheap, bounded sub-agent that returns only a
# conclusion. Tune its model / request cap here.
# MILL_WEB_SEARCH=true
# MILL_WEB_RESEARCH_MODEL=tencent/hy3-preview
# MILL_WEB_RESEARCH_REQUEST_LIMIT=8

# --- Worker safety net -------------------------------------------------
# If a ticket re-enters the same model-driven stage this many times
# without ever progressing (e.g. runs repeatedly interrupted before any
# checkpoint), the worker escalates it to BLOCKED + notifies instead of
# silently re-billing the LLM. Poll stages (in_review) are exempt.
# MILL_MAX_STUCK_CYCLES=3

# --- Human approval gate -----------------------------------------------
# When true (default), refinement pauses the pipeline at awaiting_approval
# so a human can review the refined spec before the implement stage
# starts. Set false for fully-autonomous refine → implement chaining.
MILL_REQUIRE_APPROVAL=true

# --- Command sandbox ---------------------------------------------------
# The implement agent's shell + the test command ALWAYS run in a
# disposable, network-less sibling container (there is no local mode —
# it was unsafe). Running the pipeline therefore needs the Docker
# socket (see docker-compose.yml). The unit test suite does NOT need
# Docker — it fakes the sandbox seam.
MILL_SANDBOX_IMAGE=python:3.14-slim
# MILL_SANDBOX_MEMORY=2g
# MILL_SANDBOX_PIDS_LIMIT=512
# MILL_SANDBOX_READONLY=true
# GID owning /var/run/docker.sock on the host:
#   stat -c %g /var/run/docker.sock
DOCKER_GID=999

# --- Pipeline tail (merge poll + retrospect) ---------------------------
# in_review (PR open) re-check cadence — the only timer in mill.
# MILL_MERGE_POLL_SECONDS=120
# Retrospect may file an improvement draft. With MILL_REQUIRE_APPROVAL=true
# (default), that draft will pause at awaiting_approval, bounding the loop.
# Set false to analyse without spawning.
# MILL_RETROSPECT_SPAWN_DRAFTS=true
# Path to the agent-maintained Markdown memory ledger.  Defaults to
# <MILL_DATA_DIR>/retrospect_memory.md when unset.
# MILL_RETROSPECT_MEMORY_PATH=
# When true (default) the workspace's repo/ clone is deleted on close
# to save disk space.  Disable for post-mortem inspections.
# MILL_PRUNE_CLONE_ON_CLOSE=true

# --- Audit agent (meta-audit for quality/security coverage) -----------
# Enable periodic audit passes (default: false — opt-in).
# MILL_AUDIT_PERIODIC=false
# Interval between automatic audit passes in seconds (default: 3600 = 1h).
# MILL_AUDIT_INTERVAL_SECONDS=3600
# Path to the audit agent's Markdown memory ledger. Defaults to
# <MILL_DATA_DIR>/audit_memory.md when unset.
# MILL_AUDIT_MEMORY_PATH=

# --- Forge delivery (only used by the deliver stage) -------------------
# Full procedure: docs/github-app.md
# FORGE_KIND: github | gitlab | none
FORGE_KIND=none
FORGE_REMOTE_URL=
FORGE_TARGET_BRANCH=main
# FORGE_AUTH: token (PAT) | app (GitHub App bot — recommended)
FORGE_AUTH=token
# token mode:
FORGE_TOKEN=
# app mode (bot identity <app-slug>[bot]):
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/app.pem
# GITHUB_APP_PRIVATE_KEY=        # or inline PEM, newlines as \n
# GitHub Enterprise only:
# MILL_GITHUB_API_URL=https://api.github.com

# --- Tracing (optional; leave blank to disable) ------------------------
LANGFUSE_BASE_URL=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# --- Notifications (optional) ------------------------------------------
# ntfy.sh push notifications for human-attention states
# (awaiting_approval, in_review, blocked, errored).
# Leave blank to disable.
# NTFY_URL=https://ntfy.sh/mytopic
# NTFY_TOKEN=tk_...
