# Example environment variables for robotsix-auto-mail.
#
# This file is a **documentation artifact** — it lists every MAIL_*
# variable the CLI accepts.  The application does NOT parse .env files
# at runtime (no python-dotenv).  Set these in your shell, docker-compose
# env block, CI, or IDE before invoking the CLI.
#
# Format is compatible with:
#   - direnv (via `dotenv` in .envrc)
#   - IDE auto-detection (VSCode, PyCharm)
#   - Manual shell sourcing:  set -a && source .env.example && set +a
#   - CI env: blocks (GitHub Actions, etc.)
#
# See also config/mail.local.example.yaml for the file-based equivalent.

# ---------------------------------------------------------------------------
# IMAP (incoming mail)
# ---------------------------------------------------------------------------

# Hostname of the IMAP server (required).
MAIL_IMAP_HOST=imap.example.com

# IMAP port (default: 993).
MAIL_IMAP_PORT=993

# TLS negotiation mode — one of "starttls", "direct-tls", "none" (default: direct-tls).
MAIL_IMAP_TLS_MODE=direct-tls

# IMAP folder (mailbox) to watch for new mail (default: INBOX).
MAIL_IMAP_FOLDER=INBOX

# ---------------------------------------------------------------------------
# SMTP (outgoing mail)
# ---------------------------------------------------------------------------

# Hostname of the SMTP server (required).
MAIL_SMTP_HOST=smtp.example.com

# SMTP port (default: 587).
MAIL_SMTP_PORT=587

# TLS negotiation mode — one of "starttls", "direct-tls", "none" (default: starttls).
MAIL_SMTP_TLS_MODE=starttls

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------

# Login username — typically the full email address (required).
MAIL_USERNAME=user@example.com

# Login password — will be masked in logs/repr (required).
MAIL_PASSWORD=your-password-here

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------

# Path to the SQLite database file (default: .data/mail.db).
MAIL_DB_PATH=.data/mail.db

# ---------------------------------------------------------------------------
# LLM provider detection (optional — only needed for `detect` subcommand)
# ---------------------------------------------------------------------------

# OpenRouter API key (required for detect).  Get one at https://openrouter.ai/keys
LLM_API_KEY=sk-or-v1-…

# Model to use for detection (default: deepseek/deepseek-v4-flash).
LLM_MODEL=deepseek/deepseek-v4-flash

