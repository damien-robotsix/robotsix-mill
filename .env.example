# OpenRouter API key — required by OpenRouterProvider (and derived providers).
OPENROUTER_API_KEY=sk-or-v1-...

# Langfuse tracing (optional) — uncomment and fill to enable trace/cost export.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROJECT_ID=
