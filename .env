# --- Core ---------------------------------------------------------------
# Per-agent models. The implement agent (MILL_MODEL) reads + edits the
# repo itself, kept lean by a concise `explore` scout and a distilling
# `run_tests` sub-agent. Each role has its own model so cheap models
# can be slotted in per-agent for cost leverage; ALL default to the
# capable model for now.
MILL_MODEL=deepseek/deepseek-v4-pro
# MILL_EXPLORE_MODEL=deepseek/deepseek-v4-pro     # scout (pointers only)
# MILL_WEB_RESEARCH_MODEL=deepseek/deepseek-v4-pro
# MILL_TEST_MODEL=deepseek/deepseek-v4-pro        # distills failures
# MILL_REFINE_MODEL=deepseek/deepseek-v4-pro
# MILL_RETROSPECT_MODEL=deepseek/deepseek-v4-pro
# MILL_AUDIT_MODEL=deepseek/deepseek-v4-pro
# MILL_DEDUP_MODEL=deepseek/deepseek-v4-pro       # pre-refine dedup check (cheap)
# MILL_COORDINATOR_REQUEST_LIMIT=200
# MILL_MAX_FIX_ITERATIONS=8   # implement->test cycles before BLOCK
# Bounded retry for TRANSIENT failures (HTTP 429/5xx, conn/read
# timeouts) on every model call and the ntfy POST. Non-transient
# errors (other 4xx, budget caps) are never retried. Backoff is
# exponential, jittered and capped.
# Hard per-request timeout on every model call (seconds); a hung/
# glacial provider then raises -> transient -> retried, instead of
# freezing the single worker forever.
# MILL_MODEL_REQUEST_TIMEOUT=900  # > v4-pro tail latency; only catches true hangs
# MILL_TRANSIENT_RETRIES=4
# MILL_TRANSIENT_BACKOFF_BASE=2.0
# MILL_TRANSIENT_BACKOFF_CAP=30.0
# Per-call cap for the read-only exploration sub-agent the
# coordinator uses instead of reading the repo into its own context.
# MILL_EXPLORE_REQUEST_LIMIT=20

# Where the SQLite DB and per-ticket workspaces live. Leave UNSET for
# local dev — the code defaults to a repo-local ./.mill-data/. The
# Docker image sets this to /data itself; only override for a custom
# path.
# MILL_DATA_DIR=.mill-data

# --- Pre-refine dedup guard --------------------------------------------
# Before the expensive refine agent runs, a single cheap LLM call checks
# whether the draft is (a) a duplicate of an existing ticket or (b)
# already implemented in a recent commit.  When a match is found the
# ticket is short-circuited to CLOSED — no refiner, no approval gate,
# no wasted cost.
# MILL_DEDUP_MODEL=deepseek/deepseek-v4-pro  # model for the dedup check
# MILL_DEDUP_REQUEST_LIMIT=4                 # per-call request cap (keep tight)
# MILL_DEDUP_LOOKBACK_DAYS=30                # how many days back closed tickets are dup candidates
# MILL_DEDUP_LOOKBACK_COMMITS=20             # how many recent commits to inspect for "already done"

# --- Management-plane service ------------------------------------------
# Leave UNSET locally (code default 127.0.0.1). The Docker image sets
# this to 0.0.0.0 itself so the port is reachable from the host.
# MILL_API_HOST=127.0.0.1
MILL_API_PORT=8077
# Base URL the CLI client uses (inside the container).
MILL_API_URL=http://127.0.0.1:8077

# --- Web research sub-agent --------------------------------------------
# No agent ever uses OpenRouter ":online" (a per-request surcharge);
# web lookups are delegated to this bounded sub-agent that returns only
# a conclusion. Model is set above (MILL_WEB_RESEARCH_MODEL).
# MILL_WEB_SEARCH=true
# MILL_WEB_RESEARCH_REQUEST_LIMIT=8

# --- Worker pool -------------------------------------------------------
# How many tickets are processed IN PARALLEL (cross-ticket; a single
# ticket's stages still run in order). Each in-flight implement may
# spawn a sandbox container + hit the model API, so keep it modest.
# MILL_MAX_CONCURRENCY=4

# --- Worker safety net -------------------------------------------------
# If a ticket re-enters the same model-driven stage this many times
# without ever progressing (e.g. runs repeatedly interrupted before any
# checkpoint), the worker escalates it to BLOCKED + notifies instead of
# silently re-billing the LLM. Poll stages (in_review) are exempt.
# MILL_MAX_STUCK_CYCLES=3

# --- Human approval gate -----------------------------------------------
# When true (default), refinement pauses the pipeline at awaiting_approval
# so a human can review the refined spec before the implement stage
# starts. Set false for fully-autonomous refine → implement chaining.
MILL_REQUIRE_APPROVAL=true

# --- Command sandbox ---------------------------------------------------
# The implement agent's shell + the test command ALWAYS run in a
# disposable, network-less sibling container (there is no local mode —
# it was unsafe). Running the pipeline therefore needs the Docker
# socket (see docker-compose.yml). The unit test suite does NOT need
# Docker — it fakes the sandbox seam.
MILL_SANDBOX_IMAGE=python:3.14-slim
# MILL_SANDBOX_MEMORY=2g
# MILL_SANDBOX_PIDS_LIMIT=512
# MILL_SANDBOX_READONLY=true
# GID owning /var/run/docker.sock on the host:
#   stat -c %g /var/run/docker.sock
DOCKER_GID=999

# --- Pipeline tail (merge poll + retrospect) ---------------------------
# in_review (PR open) re-check cadence — the only timer in mill.
# MILL_MERGE_POLL_SECONDS=120
# Max rebase attempts for stale in_review PRs that have become
# conflicting (other PRs merged to the target). Each attempt invokes
# the rebase agent once. After exhausting attempts the ticket is
# escalated to BLOCKED (resumable). Default 2.
# MILL_REBASE_MAX_ATTEMPTS=2
# Max CI-fix attempts for in_review PRs whose checks are failing.
# Each attempt invokes the ci-fix agent once. After exhausting
# attempts the ticket is escalated to BLOCKED (resumable). Default 2.
# MILL_CI_FIX_MAX_ATTEMPTS=2
# Retrospect may file an improvement draft. With MILL_REQUIRE_APPROVAL=true
# (default), that draft will pause at awaiting_approval, bounding the loop.
# Set false to analyse without spawning.
# MILL_RETROSPECT_SPAWN_DRAFTS=true
# Path to the agent-maintained Markdown memory ledger.  Defaults to
# <MILL_DATA_DIR>/retrospect_memory.md when unset.
# MILL_RETROSPECT_MEMORY_PATH=
# When true (default) the workspace's repo/ clone is deleted on close
# to save disk space.  Disable for post-mortem inspections.
# MILL_PRUNE_CLONE_ON_CLOSE=true

# --- Audit agent (meta-audit for quality/security coverage) -----------
# Enable periodic audit passes (default: false — opt-in).
# MILL_AUDIT_PERIODIC=false
# Interval between automatic audit passes in seconds (default: 3600 = 1h).
# MILL_AUDIT_INTERVAL_SECONDS=3600
# Path to the audit agent's Markdown memory ledger. Defaults to
# <MILL_DATA_DIR>/audit_memory.md when unset.
# MILL_AUDIT_MEMORY_PATH=

# --- Trace-health check ------------------------------------------------
# Enable periodic trace-health checks (default: false — opt-in).
# Checks Langfuse for unsessioned traces and files a draft ticket
# when any are detected.
# MILL_TRACE_HEALTH_PERIODIC=false
# Interval between automatic trace-health checks in seconds (default: 86400 = 1d).
# Minimum enforced in the worker is 3600s (1h) to avoid hammering Langfuse.
# MILL_TRACE_HEALTH_INTERVAL_SECONDS=86400

# --- Forge delivery (only used by the deliver stage) -------------------
# Full procedure: docs/github-app.md
# FORGE_KIND: github | gitlab | none
FORGE_KIND=none
FORGE_REMOTE_URL=
FORGE_TARGET_BRANCH=main
# FORGE_AUTH: token (PAT) | app (GitHub App bot — recommended)
FORGE_AUTH=token
# GitHub Enterprise only:
# MILL_GITHUB_API_URL=https://api.github.com

# --- Web fetch ---------------------------------------------------------
MILL_WEB_SEARCH=true
MILL_WEB_RESEARCH_REQUEST_LIMIT=8
MILL_WEB_FETCH_MAX_BYTES=2000000
MILL_WEB_FETCH_TIMEOUT=30
MILL_FETCH_IMAGE=curlimages/curl:8.17.0

# --- Skills ------------------------------------------------------------
MILL_SKILLS_DIR=skills

# --- Safety nets -------------------------------------------------------
MILL_MAX_STUCK_CYCLES=3
MILL_MAX_SPEND_USD_PER_TICKET=0.0

# --- Review gate -------------------------------------------------------
# MILL_REVIEW_ENABLED=false
# MILL_REVIEW_MODEL=deepseek/deepseek-v4-pro

# --- Doc agent ---------------------------------------------------------
# MILL_DOC_MODEL=deepseek/deepseek-v4-pro

# --- Sandbox data mount ------------------------------------------------
MILL_DATA_VOLUME=mill_data
# Set by docker-compose; unset for local dev.
# MILL_SANDBOX_DATA_MOUNT=

# --- Trace inspector ---------------------------------------------------
# MILL_TRACE_INSPECTOR_MODEL=deepseek/deepseek-v4-pro
# Path defaults to <data_dir>/trace_inspector_memory.md when unset.
# MILL_TRACE_INSPECTOR_MEMORY_PATH=

# --- Retrospect deep analysis ------------------------------------------
# MILL_RETROSPECT_DEEP_ANALYSIS_FREQUENCY=10

# --- Rate-limit fallback -----------------------------------------------
# MILL_RATE_LIMIT_BACKOFF_BASE=30.0
# MILL_RATE_LIMIT_BACKOFF_CAP=120.0
# MILL_RATE_LIMIT_FALLBACK_RETRIES=3
MILL_RATE_LIMIT_FALLBACK_MODEL=

# --- Explore / test / dedup limits ------------------------------------
# MILL_EXPLORE_REQUEST_LIMIT=20
# MILL_DEDUP_REQUEST_LIMIT=4
# MILL_TEST_REQUEST_LIMIT=8

# --- Memory ------------------------------------------------------------
# MILL_MAX_MEMORY_CHARS=8000

# --- CI monitor --------------------------------------------------------
# MILL_CI_MONITOR_PERIODIC=false
# MILL_CI_MONITOR_INTERVAL_SECONDS=3600
# MILL_CI_LOG_MAX_BYTES=65536

# --- Test-gap agent ----------------------------------------------------
# MILL_TEST_GAP_MODEL=deepseek/deepseek-v4-pro
# MILL_TEST_GAP_PERIODIC=false
# MILL_TEST_GAP_INTERVAL_SECONDS=86400
# Path defaults to <data_dir>/test_gap_memory.md when unset.
# MILL_TEST_GAP_MEMORY_PATH=

# --- Agent-check agent -------------------------------------------------
# MILL_AGENT_CHECK_MODEL=deepseek/deepseek-v4-pro
# Path defaults to <data_dir>/agent_check_memory.md when unset.
# MILL_AGENT_CHECK_MEMORY_PATH=
# MILL_AGENT_CHECK_PERIODIC=false
# MILL_AGENT_CHECK_INTERVAL_SECONDS=86400

# --- Health agent ------------------------------------------------------
# MILL_HEALTH_MODEL=deepseek/deepseek-v4-pro
# MILL_HEALTH_PERIODIC=false
# MILL_HEALTH_INTERVAL_SECONDS=86400
# Path defaults to <data_dir>/health_memory.md when unset.
# MILL_HEALTH_MEMORY_PATH=

# --- Survey agent ------------------------------------------------------
# MILL_SURVEY_MODEL=deepseek/deepseek-v4-pro
# Path defaults to <data_dir>/survey_memory.md when unset.
# MILL_SURVEY_MEMORY_PATH=

# --- Action-agent memory paths -----------------------------------------
# Path defaults to <data_dir>/implement_memory.md when unset.
# MILL_IMPLEMENT_MEMORY_PATH=
# MILL_REFINE_MEMORY_PATH=
# MILL_CI_FIX_MEMORY_PATH=
# MILL_REBASE_MEMORY_PATH=

# --- Test / command ----------------------------------------------------
MILL_TEST_COMMAND=pytest -q
MILL_BRANCH_PREFIX=mill/
MILL_COMMAND_TIMEOUT=900

# --- Notifications (optional) ------------------------------------------
# ntfy.sh push notifications for human-attention states
# (awaiting_approval, in_review, blocked, errored).
# Leave blank to disable.
# NTFY_URL=https://ntfy.sh/mytopic
NTFY_URL=

# --- Tracing (optional; leave blank to disable) ------------------------
LANGFUSE_BASE_URL=
