# Keep local-only artifacts out of the build context so they can't be
# baked into the image (notably .mill-data).
.git
.venv
venv
.mill-data
.pytest_cache
__pycache__
*.py[cod]
*.egg-info
dist
build

# Documentation (not needed at runtime — the image runs `robotsix-mill`,
# not a doc server).
docs/
mkdocs.yml
AGENT.md
CONTRIBUTING.md
SECURITY.md
LICENSE

# Build & CI configuration (not needed in the image).
Dockerfile
.dockerignore
.github/
.hadolint.yaml
.jscpd.json
.pre-commit-config.yaml
.trivyignore
Makefile

# Example / dev configs (not needed at runtime).
docker-compose.override.example.yml
dev/

# Test coverage artifact (NOT tests/ — the dev stage doubles as the
# sandbox image and needs tests/ for the in-sandbox pytest gate).
.coverage
