# --- Secrets -----------------------------------------------------------
# Copy to secrets.env and fill in your credentials:
#   cp secrets.env.example secrets.env
#
# This file is git-ignored; secrets.env is loaded AFTER .env so any
# variable defined here overrides the same key in .env.

# OpenRouter API key for all pydantic-ai model calls.
OPENROUTER_API_KEY=

# Forge delivery credentials (used by the deliver stage).
# Full procedure: docs/github-app.md
FORGE_TOKEN=

# GitHub App bot identity (alternative to FORGE_TOKEN).
# GITHUB_APP_ID=
# GITHUB_APP_PRIVATE_KEY=        # inline PEM, newlines as \n
# GITHUB_APP_PRIVATE_KEY_PATH=/path/to/app.pem

# ntfy.sh notification authentication (optional).
NTFY_TOKEN=
