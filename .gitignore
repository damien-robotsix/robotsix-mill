.venv/
__pycache__/
*.pyc
*.pyo
dist/
*.egg-info/
.mypy_cache/
.ruff_cache/
.pytest_cache/

# Environment files (may contain credentials)
.env
.env.*
!.env.example

# Real mail configuration (may contain credentials)
config/mail.local.yaml

# Runtime SQLite store written by the ingest pipeline. The default store
# location is ./.data/mail.db (a git-ignored directory next to the working
# directory); inside Docker it lives on the mail_data named volume.
/.data/
*.db
*.db-journal
*.db-wal
*.db-shm
