#!/usr/bin/env python3
"""Migrate configuration from ``.env`` + ``secrets.env`` to YAML.

Reads every active (uncommented, non-empty) line from ``.env`` and
``secrets.env``, maps each ``MILL_*`` / ``FORGE_*`` / non-prefixed var
to its YAML dotted path per the mapping table in RFC §4.2, and writes:

- ``config/mill.production.yaml`` — non-secret overrides (values that
  differ from the committed defaults).
- ``config/secrets.yaml`` — all secret values.

The script is idempotent — running it twice produces the same output.

.. code-block:: bash

    python scripts/migrate-config [--dry-run]
"""

from __future__ import annotations

import sys
from pathlib import Path

import yaml

from robotsix_mill.config import Secrets
from robotsix_mill.config_loader import _YAML_PATH_TO_ALIAS, load_yaml_config

# Output targets, relative to the repo root (the current working
# directory when the script is invoked).
_PRODUCTION_FILE = Path("config") / "mill.production.yaml"
_SECRETS_FILE = Path("config") / "secrets.yaml"

# Input env files, relative to the repo root.
_ENV_FILES = (Path(".env"), Path("secrets.env"))

# Sentinel for "no committed default at this dotted path".
_MISSING = object()


def _strip_quotes(value: str) -> str:
    """Strip a single matched pair of surrounding quotes, if present."""
    if len(value) >= 2 and value[0] == value[-1] and value[0] in ("'", '"'):
        return value[1:-1]
    return value


def parse_env_file(path: Path) -> dict[str, str]:
    """Parse ``KEY=VALUE`` pairs from an env file.

    Skips blank lines and comment lines (first non-whitespace char is
    ``#``). Tolerates an optional leading ``export `` prefix. Strips
    surrounding whitespace from the key and a single matched pair of
    surrounding quotes from the value. A missing file is treated as
    empty (returns ``{}``).
    """
    if not path.exists():
        return {}

    result: dict[str, str] = {}
    for raw_line in path.read_text().splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#"):
            continue
        if line.startswith("export ") or line.startswith("export\t"):
            line = line[len("export ") :].strip()
        if "=" not in line:
            continue
        key, value = line.split("=", 1)
        key = key.strip()
        if not key:
            continue
        result[key] = _strip_quotes(value.strip())
    return result


def build_alias_to_path(path_to_alias: dict[str, str]) -> dict[str, str]:
    """Build the inverse ``alias -> dotted_path`` map.

    When multiple dotted paths map to the same alias, the first by
    sorted dotted-path order wins so behavior is deterministic.
    """
    inverse: dict[str, str] = {}
    for dotted in sorted(path_to_alias):
        alias = path_to_alias[dotted]
        inverse.setdefault(alias, dotted)
    return inverse


def resolve_dotted_path(key: str, alias_to_path: dict[str, str]) -> str | None:
    """Resolve an env-var KEY to its YAML dotted path, or ``None``.

    (a) If KEY is directly an alias, use it.
    (b) Else if KEY starts with ``MILL_``, try ``KEY[5:].lower()`` as an
        alias.
    """
    if key in alias_to_path:
        return alias_to_path[key]
    if key.startswith("MILL_"):
        alias = key[len("MILL_") :].lower()
        if alias in alias_to_path:
            return alias_to_path[alias]
    return None


def _lookup_default(defaults: dict, dotted: str) -> object:
    """Look up the committed default at a dotted path, or ``_MISSING``."""
    node: object = defaults
    for part in dotted.split("."):
        if isinstance(node, dict) and part in node:
            node = node[part]
        else:
            return _MISSING
    return node


def _coerce_to_type(value: str, default: object) -> object:
    """Coerce an env-var string toward the committed default's type."""
    # ``bool`` must be checked before ``int`` (bool is an int subclass).
    if isinstance(default, bool):
        low = value.strip().lower()
        if low in ("true", "1", "yes", "on"):
            return True
        if low in ("false", "0", "no", "off"):
            return False
        return value
    if isinstance(default, int):
        try:
            return int(value)
        except ValueError:
            return value
    if isinstance(default, float):
        try:
            return float(value)
        except ValueError:
            return value
    return value


def _set_nested(root: dict, dotted: str, value: object) -> None:
    """Assign ``value`` into ``root`` following a dotted path."""
    parts = dotted.split(".")
    node = root
    for part in parts[:-1]:
        child = node.setdefault(part, {})
        node = child
    node[parts[-1]] = value


def build_outputs(
    env_vars: dict[str, str],
    defaults: dict,
    *,
    alias_to_path: dict[str, str] | None = None,
    secret_fields: set[str] | None = None,
) -> tuple[dict, dict, list[str]]:
    """Split env vars into production overrides, secrets, and unmapped.

    Returns ``(production, secrets, unmapped)`` where ``production`` is a
    nested dict mirroring the dotted paths (only values that differ from
    the committed defaults), ``secrets`` is a flat dict keyed by the
    lowercased env-var name, and ``unmapped`` is the sorted list of
    non-secret keys that resolved to no dotted path.
    """
    if alias_to_path is None:
        alias_to_path = build_alias_to_path(_YAML_PATH_TO_ALIAS)
    if secret_fields is None:
        secret_fields = set(Secrets.model_fields)

    production: dict = {}
    secrets: dict = {}
    unmapped: list[str] = []

    for key, value in env_vars.items():
        if key.lower() in secret_fields:
            secrets[key.lower()] = value
            continue
        dotted = resolve_dotted_path(key, alias_to_path)
        if dotted is None:
            unmapped.append(key)
            continue
        default = _lookup_default(defaults, dotted)
        if default is _MISSING:
            _set_nested(production, dotted, value)
        else:
            coerced = _coerce_to_type(value, default)
            if coerced != default:
                _set_nested(production, dotted, coerced)

    return production, secrets, sorted(unmapped)


def _dump_yaml(data: dict) -> str:
    """Serialize a dict to deterministic YAML."""
    text: str = yaml.safe_dump(data, sort_keys=True, default_flow_style=False)
    return text


def main(argv: list[str] | None = None) -> int:
    """Run the migration. Returns a process exit code."""
    argv = list(sys.argv if argv is None else argv)
    dry_run = "--dry-run" in argv

    env_paths = [Path(p) for p in _ENV_FILES]
    present = [p for p in env_paths if p.exists()]

    if not present:
        print(
            "Nothing to migrate: neither "
            + " nor ".join(str(p) for p in env_paths)
            + " exists."
        )
        return 0

    env_vars: dict[str, str] = {}
    for path in env_paths:
        if path.exists():
            env_vars.update(parse_env_file(path))
        else:
            print(f"Note: {path} does not exist — treating as empty.")

    defaults = load_yaml_config(config_file="", skip_local=True)
    production, secrets, unmapped = build_outputs(env_vars, defaults)

    if unmapped:
        print("Unmapped (skipped) vars: " + ", ".join(unmapped))

    if dry_run:
        print("[dry-run] No files written. Would write:")
        print(f"  {_PRODUCTION_FILE}:")
        if production:
            for line in _dump_yaml(production).splitlines():
                print(f"    {line}")
        else:
            print("    (no non-secret overrides)")
        print(f"  {_SECRETS_FILE}:")
        if secrets:
            for skey in sorted(secrets):
                print(f"    {skey}: ***")
        else:
            print("    (no secrets)")
        return 0

    _PRODUCTION_FILE.parent.mkdir(parents=True, exist_ok=True)
    _PRODUCTION_FILE.write_text(_dump_yaml(production))
    _SECRETS_FILE.parent.mkdir(parents=True, exist_ok=True)
    _SECRETS_FILE.write_text(_dump_yaml(secrets))

    print(
        f"Wrote {_PRODUCTION_FILE} "
        f"({len(production)} top-level section(s)) and "
        f"{_SECRETS_FILE} ({len(secrets)} secret(s))."
    )
    return 0


if __name__ == "__main__":
    sys.exit(main())
